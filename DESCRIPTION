Package: artbin
Title: Sample Size and Power for Binary Outcome Clinical Trials
Version: 2.1.2
Authors@R: c(
    person("Ian", "White", email = "ian.white@ucl.ac.uk", role = c("aut", "cre")),
    person("Ella", "Marley-Zagar", role = "aut"),
    person("Abdel", "Babiker", role = "aut"),
